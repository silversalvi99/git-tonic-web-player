{
  "name": "gin-tonic-web-player",
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "prepare": "husky",
    "lint": "ng lint",
    "playwright-tests": "npm run build && npx playwright test",
    "playwright-tests-ui": "npm run build && npx playwright test --ui"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.10.1",
  "dependencies": {
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/platform-browser-dynamic": "21.2.5",
    "@angular/router": "21.2.5",
    "@ng-icons/core": "^33.1.0",
    "@ng-icons/heroicons": "^33.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.3",
    "rxjs": "~7.8.0",
    "ts-md5": "^2.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular/build": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.5",
    "@angular/platform-browser-dynamic": "21.2.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^25.5.0",
    "angular-eslint": "21.3.0",
    "dotenv": "^17.4.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "undici": "^7.24.0",
    "picomatch": "^4.0.3",
    "brace-expansion": "^5.0.4"
  },
  "lint-staged": {
    "*.{ts,js,json,md,html,css,scss}": "prettier --write",
    "*.ts": "eslint --fix"
  }
}
